model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-IN
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["fact_sales_fulfillment","silver_geolocaiton","gold_daily_logistics_summary","gold_product_category_ranking","gold_sellers_performance","gold_customer_installment_correlation","gold_geographic_revenue_density"]

annotation PBI_ProTooling = ["DevMode"]

ref table fact_sales_fulfillment
ref table silver_geolocaiton
ref table gold_daily_logistics_summary
ref table gold_product_category_ranking
ref table gold_sellers_performance
ref table gold_customer_installment_correlation
ref table gold_geographic_revenue_density

ref cultureInfo en-US

